<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.17">
  <POU Name="FB_InputConvVFD" Id="{dad210e1-1825-4235-b96b-6c351ce5f09a}" SpecialFunc="None">
    <Declaration><![CDATA[//Generate commands to a drive.
FUNCTION_BLOCK FB_InputConvVFD

VAR_INPUT
	bStop				:BOOL; // Stop command - resets SRAMP and forces velocity to zero
    bRunFWR				:BOOL; // Run forward command
	bRunREV				:BOOL; // Run reverse command
	bJog		:BOOL; // Jog command (treated the same as forward run)
	iVoltage		:REAL; // Analog speed reference voltage [V]
	iVoltageMax		:REAL; // Maximum analog reference voltage [V] (typically 10 V)
    rAccTime		:REAL;      // Acc in seconds
    rDecTime		:REAL;      // DEC in seconds
	iMotorMaxSpeed	:REAL; // Motor rated speed at 50 Hz [RPM]
	ConveyorVelocityMax :REAL; // Maximum conveyor belt velocity at motor max speed [m/s]
	
END_VAR

VAR_OUTPUT
	bSpeedReached	:BOOL; // TRUE when drive output frequency matches the reference
	bFault			:BOOL; // Drive fault flag (not implemented in simulation)
	bRunning		:BOOL; // TRUE when drive is running with a positive frequency reference
	rDriveVelProfile	:REAL;   // Simulated Motor vel profile
	rDriveACCProfile	:REAL; // Simulated Motor acc profile
	
END_VAR

VAR
	DriveRun		:BOOL; // TRUE when exactly one direction command is active (XOR result)
    DriveRunFWR		:BOOL; // Internal forward run (RunFWR OR Jog)
    DriveRunREV		:BOOL; // Internal reverse run
    DriveHzRef		:REAL; // Target frequency reference [Hz], ±HzMax
	rAccRate		:REAL; // Acceleration rate [Hz/s]
    rDecRate		:REAL; // Deceleration rate [Hz/s] (negative value)
	rDirSign 		:REAL; // Direction sign: +1.0 forward, -1.0 reverse
	fbSRAMP :SRAMP; // OSCAT S-ramp function block for smooth velocity profiling
	HzMax :REAL := 50; // Maximum drive frequency [Hz]
	rRPMvel :REAL; // Simulated motor shaft speed [RPM]
	rLinearVel :REAL; // Simulated conveyor belt linear velocity [m/s]
	sStatus		:STRING(120);	// STATUS text

END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[// Run command
DriveRunFWR := bRunFWR OR bJog;
DriveRunREV := bRunREV;

DriveRun := (DriveRunFWR XOR DriveRunREV);   // TRUE only if one is on

IF bRunFWR OR bJog THEN
    rDirSign := 1.0;
ELSIF bRunREV THEN
    rDirSign := -1.0;

END_IF;

//Voltage to Hz:
IF iVoltage <= 0.0  THEN //OR NOT DriveRun
    DriveHzRef := 0.0;
ELSIF iVoltage > iVoltageMax THEN
    DriveHzRef := HzMax;
ELSE
    DriveHzRef := (iVoltage / iVoltageMax) * HzMax;
END_IF;


IF ABS(DriveHzRef) < 0.001 AND rAccTime > 0 THEN
    rAccRate := (HzMax / 2) / rAccTime;
ELSIF rAccTime > 0.01 THEN
    rAccRate := DriveHzRef / rAccTime;
ELSE
    rAccRate := DriveHzRef * 10.0;
END_IF;

IF ABS(DriveHzRef) < 0.001 AND rDecTime > 0 THEN
    rDecRate := (HzMax / 2) / -rDecTime;
ELSIF rDecTime > 0.01 THEN
	rDecRate := DriveHzRef / -rDecTime;   // Hz/s
ELSE
	rDecRate := DriveHzRef * -10.0;      // Hz/s
END_IF;

// Determine target input
IF DriveRun THEN 
	DriveHzRef := DriveHzRef * rDirSign;
ELSE
	DriveHzRef := 0.0;
END_IF;

// SRAMP function to build velocity command
fbSRAMP(
    X           := DriveHzRef,
    A_UP        := rAccRate,
    A_DN        := rDecRate,
    VU_MAX      := rAccRate *1000,     // Jerk
    VD_MAX      := rDecRate *1000,     // Jerk
    LIMIT_HIGH  := HzMax,
    LIMIT_LOW   := -HzMax,
    RST         := bStop ,
    Y           => rDriveVelProfile,
    V           => rDriveACCProfile // Acctual Acc
);

rRPMvel := rDriveVelProfile/HzMax * iMotorMaxSpeed;
rLinearVel := rDriveVelProfile/HzMax * ConveyorVelocityMax;

//Status
bSpeedReached := (rDriveVelProfile = DriveHzRef AND DriveRun );
bRunning      := (DriveHzRef > 0 AND DriveRun);

//Drive Status (priority-based)
IF bStop THEN
    // SRAMP reset → forced stop
    sStatus := 'STOP';

ELSIF (DriveRunFWR AND DriveRunREV) THEN
    // Illegal command combination
    sStatus := 'Command Conflict: Run Farward and Reverse';

ELSIF NOT DriveRun THEN
    // No valid run command (XOR result = FALSE)
    sStatus := 'Stopped (No specific direction Run Command)';

ELSE
    // DriveRun = TRUE (exactly one direction active)

    IF bRunFWR OR bJog THEN
        sStatus := 'Running Farward';

    ELSIF bRunREV THEN
        sStatus := 'Running Reverse';

    END_IF
END_IF;
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>